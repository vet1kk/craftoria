{
  "info": {
    "name": "Craftoria API",
    "description": "API collection for Craftoria application. For protected routes, first call 'Get Session' to get CSRF token, then 'Login' to authenticate. Postman will automatically store cookies.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
