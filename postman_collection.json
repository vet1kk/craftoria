{
  "info": {
    "name": "Craftoria API",
    "description": "API collection for Craftoria. Auth uses JWT bearer tokens. Run Login or Register first to save {{jwt_token}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const method = pm.request.method;",
          "const url = pm.request.url.toString();",
          "const status = pm.response.code;",
          "",
          "pm.test('[Auto] Response is not 5xx', () => {",
          "  pm.expect(status).to.be.below(500);",
          "});",
          "",
          "pm.test('[Auto] Response time is under 5s', () => {",
          "  pm.expect(pm.response.responseTime).to.be.below(5000);",
          "});",
          "",
          "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
          "const hasBody = (pm.response.text() || '').length > 0;",
          "const isJson = contentType.includes('application/json');",
          "",
          "if (status !== 204 && hasBody) {",
          "  pm.test('[Auto] Non-empty response uses JSON', () => {",
          "    pm.expect(isJson).to.eql(true);",
          "  });",
          "}",
          "",
          "let json = null;",
          "if (isJson && hasBody) {",
          "  try {",
          "    json = pm.response.json();",
          "  } catch (error) {",
          "    pm.test('[Auto] Response JSON can be parsed', () => {",
          "      throw error;",
          "    });",
          "  }",
          "}",
          "",
          "if (json && typeof json === 'object' && status >= 200 && status < 300) {",
          "  const hasData = Object.prototype.hasOwnProperty.call(json, 'data');",
          "  const hasMessage = Object.prototype.hasOwnProperty.call(json, 'message');",
          "  const hasAnyKey = Object.keys(json).length > 0;",
          "",
          "  pm.test('[Auto] Success payload has expected shape', () => {",
          "    pm.expect(hasData || hasMessage || hasAnyKey).to.eql(true);",
          "  });",
          "}",
          "",
          "if (method === 'DELETE' && status < 400) {",
          "  pm.test('[Auto] DELETE returns 200 or 204', () => {",
          "    pm.expect([200, 204]).to.include(status);",
          "  });",
          "}",
          "",
          "if (status >= 200 && status < 300 && json && typeof json === 'object') {",
          "  const data = json.data && typeof json.data === 'object' ? json.data : null;",
          "",
          "  if (data?.access_token) {",
          "    pm.collectionVariables.set('jwt_token', data.access_token);",
          "  }",
          "",
          "  if (data?.user?.id) {",
          "    pm.collectionVariables.set('user_id', data.user.id);",
          "  }",
          "",
          "  if (data?.id && url.includes('/categories')) {",
          "    pm.collectionVariables.set('category_id', data.id);",
          "    if (data.slug) pm.collectionVariables.set('category_slug', data.slug);",
          "  }",
          "",
          "  if (data?.id && url.includes('/products') && !url.includes('/ingredients') && !url.includes('/metadata')) {",
          "    pm.collectionVariables.set('product_id', data.id);",
          "    if (data.slug) pm.collectionVariables.set('product_slug', data.slug);",
          "  }",
          "",
          "  if (data?.id && url.includes('/ingredients') && !url.includes('/products/')) {",
          "    pm.collectionVariables.set('ingredient_id', data.id);",
          "  }",
          "",
          "  if (data?.id && url.includes('/orders') && !url.includes('/items')) {",
          "    pm.collectionVariables.set('order_id', data.id);",
          "  }",
          "",
          "  if (data?.id && url.includes('/orders/') && url.includes('/items')) {",
          "    pm.collectionVariables.set('order_item_id', data.id);",
          "  }",
          "",
          "  if (data?.id && url.includes('/products/') && url.includes('/ingredients')) {",
          "    pm.collectionVariables.set('product_ingredient_id', data.id);",
          "  }",
          "",
          "  if (data?.id && url.includes('/products/') && url.includes('/metadata')) {",
          "    pm.collectionVariables.set('metadata_id', data.id);",
          "  }",
          "}",
          "",
          "if (status === 401) {",
          "  pm.test('[Auto] Unauthorized response has auth error body', () => {",
          "    if (!json || typeof json !== 'object') return;",
          "    const hasMessage = Object.prototype.hasOwnProperty.call(json, 'message');",
          "    const hasError = Object.prototype.hasOwnProperty.call(json, 'error');",
          "    pm.expect(hasMessage || hasError).to.eql(true);",
          "  });",
          "}",
          "",
          "if (status === 422) {",
          "  pm.test('[Auto] Validation response has errors object', () => {",
          "    if (!json || typeof json !== 'object') return;",
          "    pm.expect(json.errors).to.be.an('object');",
          "  });",
          "}"
        ]
      }
    }
  ],
