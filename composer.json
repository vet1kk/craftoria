{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "craftoria/backend",
  "type": "project",
  "description": "Craftoria backend based on a fresh Laravel installation.",
  "keywords": [
    "craftoria",
    "laravel",
    "framework"
  ],
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "laravel/framework": "^13.0",
    "laravel/tinker": "^3.0",
    "mcamara/laravel-localization": "^2.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pail": "^1.2.5",
    "laravel/pint": "^1.27",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "phpunit/phpunit": "^12.5.12"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "setup": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@composer install",
      "npm -C public install",
      "@php artisan key:generate --ansi",
      "@setup:postgres",
      "@php artisan migrate",
      "#@php artisan db:seed --ansi"
    ],
    "check": [
      "@composer validate --strict",
      "@composer check-platform-reqs",
      "@php artisan route:list --except-vendor --ansi"
    ],
    "test": [
      "php vendor/bin/phpunit"
    ],
    "setup:postgres": "bash .config/postgres/run.sh setup",
    "check:postgres": "bash .config/postgres/run.sh check",
    "check:php-fpm": ".config/php/run.sh check",
    "serve": ".config/php/run.sh",
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
